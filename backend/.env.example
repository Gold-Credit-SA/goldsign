# Link de assinatura
SIGNING_LINK_EXPIRATION_DAYS=7

# Assinatura automatica da cessionaria Gold Credit no servidor (opcional)
# Para ativar: converta o arquivo .pfx/.p12 em base64 e cole aqui
#   Linux/Mac: base64 -w0 certificado.pfx
#   Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("certificado.pfx"))
# Deixe vazio para usar o fluxo manual (assinador local)
GOLD_CREDIT_PKCS12_B64=
GOLD_CREDIT_PKCS12_PASSWORD=senha-do-certificado
