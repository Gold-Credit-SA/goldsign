# Supabase
# Opcional: pode ser inferida automaticamente de SUPABASE_DB_URL
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_BUCKET=documentos-pdf

# JWT / Auth
JWT_SECRET=sua-chave-secreta-minimo-32-caracteres-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# App
APP_NAME=Assinatura Digital ICP-Brasil
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Assinatura PAdES
SIGNATURE_FIELD_NAME=AssinaturaICP
SIGNATURE_REASON=Assinatura digital conforme ICP-Brasil
SIGNATURE_LOCATION=Brasil

# Link de assinatura
SIGNING_LINK_EXPIRATION_DAYS=7
